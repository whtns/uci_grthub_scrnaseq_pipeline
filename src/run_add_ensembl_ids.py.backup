#!/usr/bin/env python
"""Add Ensembl gene IDs to an h5ad file using the adata_helpers module.

Also supports Cellarium CAS for gene annotation and cell type annotation.

Usage:
    python run_add_ensembl_ids.py [input_file] [--species SPECIES] [--var-name VAR_NAME] [--overwrite]
    python run_add_ensembl_ids.py [input_file] --use-cellarium [--cellarium-token TOKEN]

Example:
    python run_add_ensembl_ids.py output/scanpy/combined_harmony_integrated.h5ad --species human
    python run_add_ensembl_ids.py output/scanpy/combined_harmony_integrated.h5ad --use-cellarium
"""
import argparse
import sys
from pathlib import Path

import anndata as ad
import numpy as np
import pandas as pd
import scipy.sparse as sp

import grthub_tools as gt

# MyGene imports (fast batch queries)
try:
    import mygene
    MYGENE_AVAILABLE = True
except ImportError:
    MYGENE_AVAILABLE = False

# Cellarium imports
try:
    from cellarium.cas.client import CASClient
    from cellarium.cas.postprocessing import insert_cas_ontology_aware_response_into_adata
    import cellarium.cas.postprocessing.ontology_aware as pp
    from cellarium.cas.postprocessing.cell_ontology import CellOntologyCache
    from cellarium.cas._io import suppress_stderr
    CELLARIUM_AVAILABLE = True
except ImportError:
    CELLARIUM_AVAILABLE = False
    CASClient = None


def add_ensembl_ids_mygene(adata, species='human', var_name='gene_ids', overwrite=False):
    """Map gene symbols to Ensembl IDs using MyGene (much faster than REST API).
    
    MyGene queries genes in batches of 1000, making it ~50-100x faster than
    the single-query REST API approach.
    
    Parameters
    ----------
    adata : AnnData
        AnnData object with gene symbols as var index
    species : str
        Species (currently supports 'human' or 'mouse')
    var_name : str
        Column name to add to adata.var
    overwrite : bool
        Whether to overwrite existing column
    """
    if not MYGENE_AVAILABLE:
        raise ImportError(
            "mygene is required for fast batch queries. Install with: pip install mygene"
        )
    
    if var_name in adata.var.columns and not overwrite:
        print(f"Column '{var_name}' already exists. Use --overwrite to replace.")
        return
    
    print(f"\n=== Using MyGene for fast batch gene ID mapping ===")
    mg = mygene.MyGeneInfo()
    
    # Set species
    species_map = {
        'human': 'human',
        'mouse': 'mouse',
        'rat': 'rat'
    }
    if species.lower() not in species_map:
        raise ValueError(f"Species '{species}' not supported. Use: {list(species_map.keys())}")
    
    gene_symbols = adata.var.index.tolist()
    print(f"Querying {len(gene_symbols)} genes using MyGene (batch mode)...")
    
    # Query in batch (MyGene handles batching internally)
    results = mg.querymany(
        gene_symbols,
        scopes='symbol',
        fields='ensembl.gene',
        species=species_map[species.lower()],
        returnall=True,
        as_dataframe=False,
        verbose=True
    )
    
    # Parse results
    symbol_to_ensembl = {}
    for result in results['out']:
        query = result.get('query', '')
        if 'ensembl' in result:
            ensembl_data = result['ensembl']
            if isinstance(ensembl_data, list):
                # Multiple matches - take first
                ensembl_id = ensembl_data[0].get('gene', None)
            elif isinstance(ensembl_data, dict):
                ensembl_id = ensembl_data.get('gene', None)
            else:
                ensembl_id = None
            symbol_to_ensembl[query] = ensembl_id
        else:
            symbol_to_ensembl[query] = None
    
    # Map to adata
    mapped_ids = [symbol_to_ensembl.get(sym, None) for sym in gene_symbols]
    adata.var[var_name] = pd.Series(mapped_ids, index=adata.var.index)
    
    n_mapped = sum(1 for x in mapped_ids if x is not None)
    print(f"Mapped {n_mapped}/{len(gene_symbols)} genes ({100*n_mapped/len(gene_symbols):.1f}%)")
    
    if results['missing']:
        print(f"Missing: {len(results['missing'])} genes could not be mapped")


def add_ensembl_ids_from_gtf(adata, gtf_path, var_name='gene_ids', overwrite=False):
    """Map gene symbols to Ensembl IDs from a GTF annotation file (fastest option).
    
    This is the fastest method if you have a local GTF file from your reference genome.
    
    Parameters
    ----------
    adata : AnnData
        AnnData object with gene symbols as var index
    gtf_path : str or Path
        Path to GTF/GFF annotation file
    var_name : str
        Column name to add to adata.var
    overwrite : bool
        Whether to overwrite existing column
    """
    if var_name in adata.var.columns and not overwrite:
        print(f"Column '{var_name}' already exists. Use --overwrite to replace.")
        return
    
    print(f"\n=== Parsing GTF file for gene mappings ===")
    gtf_path = Path(gtf_path)
    if not gtf_path.exists():
        raise FileNotFoundError(f"GTF file not found: {gtf_path}")
    
    print(f"Reading GTF from: {gtf_path}")
    
    # Parse GTF to extract gene_id and gene_name
    symbol_to_ensembl = {}
    
    import gzip
    open_func = gzip.open if str(gtf_path).endswith('.gz') else open
    
    with open_func(gtf_path, 'rt') as f:
        for line in f:
            if line.startswith('#'):
                continue
            
            fields = line.strip().split('\t')
            if len(fields) < 9:
                continue
            
            if fields[2] != 'gene':  # Only process gene entries
                continue
            
            attributes = fields[8]
            
            # Parse attributes
            gene_id = None
            gene_name = None
            
            for attr in attributes.split(';'):
                attr = attr.strip()
                if attr.startswith('gene_id'):
                    gene_id = attr.split('"')[1]
                elif attr.startswith('gene_name'):
                    gene_name = attr.split('"')[1]
            
            if gene_name and gene_id:
                # Extract just the Ensembl ID without version
                ensembl_id = gene_id.split('.')[0]
                symbol_to_ensembl[gene_name] = ensembl_id
    
    print(f"Parsed {len(symbol_to_ensembl)} gene mappings from GTF")
    
    # Map to adata
    gene_symbols = adata.var.index.tolist()
    mapped_ids = [symbol_to_ensembl.get(sym, None) for sym in gene_symbols]
    adata.var[var_name] = pd.Series(mapped_ids, index=adata.var.index)
    
    n_mapped = sum(1 for x in mapped_ids if x is not None)
    print(f"Mapped {n_mapped}/{len(gene_symbols)} genes ({100*n_mapped/len(gene_symbols):.1f}%)")


def annotate_with_cellarium(adata, api_token, cluster_key='cluster_label', 
                            min_score=0.1, top_k=5, pseudobulk=False):
    """Annotate cells using Cellarium CAS.
    
    Parameters
    ----------
    adata : AnnData
        AnnData object with raw counts in .X
    api_token : str
        Cellarium API token
    cluster_key : str
        Column in adata.obs containing cluster labels (if pseudobulk=True)
    min_score : float
        Minimum acceptable relevance score for cell type calls
    top_k : int
        Number of top cell type calls to return
    pseudobulk : bool
        If True, create pseudobulk profiles per cluster before annotation
        
    Returns
    -------
    AnnData
        Original adata with CAS annotations added to .obs
    """
    if not CELLARIUM_AVAILABLE:
        raise ImportError(
            "cellarium-cas is required. Install with: pip install cellarium-cas"
        )
    
    print("\n=== Cellarium CAS Annotation ===")
    print(f"Initializing Cellarium CAS client...")
    cas = CASClient(api_token=api_token)
    
    # Ensure gene_ids column exists
    if 'gene_ids' not in adata.var.columns:
        print("Warning: 'gene_ids' column not found in adata.var")
        print("Attempting to add Ensembl IDs first...")
        gt.add_ensembl_ids(adata, species='human', var_name='gene_ids')
    
    # Check if we have gene_ids now
    if 'gene_ids' not in adata.var.columns or adata.var['gene_ids'].isna().all():
        raise ValueError(
            "Cannot proceed without Ensembl gene IDs. "
            "Please ensure adata.var has a 'gene_ids' column."
        )
    
    if pseudobulk:
        print(f"\nCreating pseudobulk profiles using '{cluster_key}' clusters...")
        if cluster_key not in adata.obs.columns:
            raise ValueError(f"Cluster key '{cluster_key}' not found in adata.obs")
        
        # Create pseudobulk profiles
        pseudobulk_profiles = []
        cluster_labels = []
        
        for k in adata.obs[cluster_key].unique():
            pseudobulk_profiles.append(
                np.array(adata[adata.obs[cluster_key] == k].X.mean(axis=0)).squeeze()
            )
            cluster_labels.append(k)
        
        adata_bulk = ad.AnnData(
            X=sp.csr_matrix(np.vstack(pseudobulk_profiles)),
            obs=pd.DataFrame(data={cluster_key: cluster_labels}),
            var=adata.var,
        )
        
        print(f"Created {len(cluster_labels)} pseudobulk profiles")
        print(f"Submitting pseudobulk profiles to Cellarium CAS...")
        
        # Annotate pseudobulk
        cas_response = cas.annotate_matrix_cell_type_ontology_aware_strategy(
            matrix=adata_bulk,
            chunk_size=500,
            feature_ids_column_name='gene_ids',
            feature_names_column_name='index',
            cas_model_name=None
        )
        
        # Insert response into pseudobulk adata
        insert_cas_ontology_aware_response_into_adata(cas_response, adata_bulk)
        
        # Make top-k calls for pseudobulk
    parser.add_argument(
        "--method",
        type=str,
        default="ensembl-rest",
        choices=["ensembl-rest", "mygene", "gtf"],
        help="Method for gene ID mapping: ensembl-rest (slow), mygene (fast), gtf (fastest)"
    )
    parser.add_argument(
        "--gtf-path",
        type=str,
        default=None,
        help="Path to GTF annotation file (required if --method gtf)"
    )
        print(f"Computing top-{top_k} cell type calls...")
        with suppress_stderr():
            cl = CellOntologyCache()
        
        pp.compute_most_granular_top_k_calls_single(
            adata=adata_bulk,
            cl=cl,
            min_acceptable_score=min_score,
            top_k=top_k,
            obs_prefix="cas_cell_type"
        )
        
        # Map pseudobulk labels back to original cells
        print(f"Mapping pseudobulk labels back to individual cells...")
        for i in range(1, top_k + 1):
            label_col = f'cas_cell_type_label_{i}'
            score_col = f'cas_cell_type_score_{i}'
            
            if label_col in adata_bulk.obs.columns:
                mapping = adata_bulk.obs[[cluster_key, label_col]].set_index(cluster_key)[label_col].to_dict()
                adata.obs[f'pseudobulk_{label_col}'] = adata.obs[cluster_key].map(mapping)
            
            if score_col in adata_bulk.obs.columns:
                mapping = adata_bulk.obs[[cluster_key, score_col]].set_index(cluster_key)[score_col].to_dict()
                adata.obs[f'pseudobulk_{score_col}'] = adata.obs[cluster_key].map(mapping)
        
        prGene ID mapping workflow (choose method)
        # Check if gene_ids already exists
        if args.var_name in adata.var.columns and not args.overwrite:
            print(f"Column '{args.var_name}' already exists in adata.var")
            print("Use --overwrite to replace existing values")
            sys.exit(0)
        
        if args.method == "mygene":
            # Fast batch method using MyGene
            if not MYGENE_AVAILABLE:
                print("ERROR: mygene not available. Install with: pip install mygene")
                print("Falling back to ensembl-rest method...")
                args.method = "ensembl-rest"
            else:
                add_ensembl_ids_mygene(
                    adata,
                    species=args.species,
                    var_name=args.var_name,
                    overwrite=args.overwrite
                )
        
        elif args.method == "gtf":
            # Fastest method using local GTF file
            if not args.gtf_path:
                print("ERROR: --gtf-path required when using --method gtf")
                sys.exit(1)
            add_ensembl_ids_from_gtf(
                adata,
                gtf_path=args.gtf_path,
                var_name=args.var_name,
                overwrite=args.overwrite
            )
        
        else:  # ensembl-rest (default, slowest)
            print(f"\nMapping gene symbols to Ensembl IDs (species: {args.species})...")
            print(f"This may take a while for {adata.n_vars} genes...")
            print(f"Using {args.sleep}s sleep between API calls")
            print(f"TIP: Use --method mygene for 50-100x faster mapping!")
            
            gt.add_ensembl_ids(
                adata,
                species=args.species,
                var_name=args.var_name,
                overwrite=args.overwrite,
                sleep=args.sleep,
                timeout=args.timeout
            # Make top-k calls for individual cells
        print(f"Computing top-{top_k} cell type calls for individual cells...")
        with suppress_stderr():
            cl = CellOntologyCache()
        
        pp.compute_most_granular_top_k_calls_single(
            adata=adata,
            cl=cl,
            min_acceptable_score=min_score,
            top_k=top_k,
            obs_prefix="cas_cell_type"
        )
        
        # Also make cluster-level calls if cluster labels exist
        if cluster_key in adata.obs.columns:
            print(f"Computing top-{top_k} cell type calls per cluster...")
            pp.compute_most_granular_top_k_calls_cluster(
                adata=adata,
                cl=cl,
                min_acceptable_score=min_score,
                cluster_label_obs_column=cluster_key,
                top_k=top_k,
                obs_prefix='cas_cell_type_cluster'
            )
            print(f"Added columns: cas_cell_type_cluster_label_1 to cas_cell_type_cluster_label_{top_k}")
        
        print(f"\nCellarium annotation complete!")
        print(f"Added columns: cas_cell_type_label_1 to cas_cell_type_label_{top_k}")
    
    return adata


def main():
    parser = argparse.ArgumentParser(
        description="Add Ensembl gene IDs to an AnnData h5ad file"
    )
    parser.add_argument(
        "input_file",
        type=str,
        help="Path to input h5ad file"
    )
    parser.add_argument(
        "--species",
        type=str,
        default="human",
        help="Species for Ensembl lookup (default: human)"
    )
    parser.add_argument(
        "--var-name",
        type=str,
        default="gene_ids",
        help="Name of the column to add to adata.var (default: gene_ids)"
    )
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="Overwrite existing gene_ids column if present"
    )
    parser.add_argument(
        "--output",
        type=str,
        default=None,
        help="Output file path (default: overwrites input file)"
    )
    parser.add_argument(
        "--sleep",
        type=float,
        default=0.05,
        help="Sleep duration between API calls in seconds (default: 0.05)"
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=5.0,
        help="API request timeout in seconds (default: 5.0)"
    )
    parser.add_argument(
        "--use-cellarium",
        action="store_true",
        help="Use Cellarium CAS for cell type annotation"
    )
    parser.add_argument(
        "--cellarium-token",
        type=str,
        default="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoxNCwiZXhwaXJhdGlvbiI6IjIwMjYtMDMtMTEgMTk6NTc6MzQuMjU5MzU1In0.Gs6MRlp7wwvkznrZIyyWwK8MBU2UOJOQBmagXyG4Cvg",
        help="Cellarium API token"
    )
    parser.add_argument(
        "--cluster-key",
        type=str,
        default="cluster_label",
        help="Column in adata.obs containing cluster labels (for Cellarium)"
    )
    parser.add_argument(
        "--min-score",
        type=float,
        default=0.1,
        help="Minimum acceptable relevance score for Cellarium cell type calls (default: 0.1)"
    )
    parser.add_argument(
        "--top-k",
        type=int,
        default=5,
        help="Number of top cell type calls to return from Cellarium (default: 5)"
    )
    parser.add_argument(
        "--pseudobulk",
        action="store_true",
        help="Use pseudobulk approach for Cellarium annotation (aggregate by cluster)"
    )
    
    args = parser.parse_args()
    
    # Validate input file exists
    input_path = Path(args.input_file)
    if not input_path.exists():
        print(f"Error: Input file not found: {args.input_file}", file=sys.stderr)
        sys.exit(1)
    
    print(f"Loading AnnData from: {args.input_file}")
    adata = ad.read_h5ad(args.input_file)
    
    print(f"AnnData shape: {adata.shape}")
    print(f"Number of genes: {adata.n_vars}")
    print(f"Gene index sample: {adata.var.index[:5].tolist()}")
    
    # Decide on workflow
    if args.use_cellarium:
        # Cellarium workflow
        if not CELLARIUM_AVAILABLE:
            print("ERROR: Cellarium is not available. Install with: pip install cellarium-cas")
            sys.exit(1)
        
        annotate_with_cellarium(
            adata,
            api_token=args.cellarium_token,
            cluster_key=args.cluster_key,
            min_score=args.min_score,
            top_k=args.top_k,
            pseudobulk=args.pseudobulk
        )
        
        # Show sample results
        cas_cols = [c for c in adata.obs.columns if c.startswith('cas_') or c.startswith('pseudobulk_cas_')]
        if cas_cols:
            print(f"\nSample Cellarium annotations:")
            print(adata.obs[cas_cols].head(10))
    
    else:
        # Traditional Ensembl ID mapping workflow
        # Check if gene_ids already exists
        if args.var_name in adata.var.columns and not args.overwrite:
            print(f"Column '{args.var_name}' already exists in adata.var")
            print("Use --overwrite to replace existing values")
            sys.exit(0)
        
        print(f"\nMapping gene symbols to Ensembl IDs (species: {args.species})...")
        print(f"This may take a while for {adata.n_vars} genes...")
        print(f"Using {args.sleep}s sleep between API calls")
        
        gt.add_ensembl_ids(
            adata,
            species=args.species,
            var_name=args.var_name,
            overwrite=args.overwrite,
            sleep=args.sleep,
            timeout=args.timeout
        )
        
        # Show results
        n_mapped = adata.var[args.var_name].notna().sum()
        print(f"\nMapping complete!")
        print(f"Successfully mapped: {n_mapped}/{adata.n_vars} genes ({100*n_mapped/adata.n_vars:.1f}%)")
        print(f"Sample mappings:")
        sample_df = adata.var[[args.var_name]].head(10)
        print(sample_df)
    
    # Save the modified AnnData
    output_path = args.output if args.output else args.input_file
    print(f"\nSaving modified AnnData to: {output_path}")
    adata.write_h5ad(output_path)
    print("Done!")


if __name__ == "__main__":
    main()
