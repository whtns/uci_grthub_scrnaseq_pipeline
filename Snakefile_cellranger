# Snakemake workflow for single-cell RNA-seq analysis with CellRanger
# Converted from test.sub SLURM script

# Load configuration
configfile: "config_cellranger.yaml"

# Extract configuration variables
SAMPLE_ID = config["sample_id"]
FASTQ_DIR = config["paths"]["fastqs"]
TRANSCRIPTOME = config["references"]["transcriptome"]
OUTPUT_DIR = config["paths"]["output"]

# Rule all - defines final outputs
rule all:
    input:
        f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/web_summary.html",
        f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/filtered_feature_bc_matrix.h5",
        f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/possorted_genome_bam.bam"

# Rule: CellRanger count
rule cellranger_count:
    input:
        fastq_dir = f"{FASTQ_DIR}/{SAMPLE_ID}_merged"
    output:
        web_summary = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/web_summary.html",
        filtered_matrix = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/filtered_feature_bc_matrix.h5",
        bam_file = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/possorted_genome_bam.bam",
        molecule_info = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/molecule_info.h5"
    params:
        sample_id = SAMPLE_ID,
        transcriptome = TRANSCRIPTOME,
        output_dir = OUTPUT_DIR,
        localcores = config["params"]["localcores"],
        localmem = config["params"]["localmem"]
    threads: 8
    resources:
        mem_mb = 131072,  # 128GB in MB
        cpus = 8,
        partition = "standard",
        account = "SBSANDME_LAB"
    shell:
        """
        module load cellranger/8.0.1
        
        cd {params.output_dir}
        
        cellranger count --id={params.sample_id} \
        --transcriptome={params.transcriptome} \
        --create-bam=true \
        --fastqs={input.fastq_dir} \
        --localcores={params.localcores} \
        --localmem={params.localmem}
        
        module unload cellranger/8.0.1
        """

# Optional rule: Generate summary report
rule generate_summary:
    input:
        web_summary = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/web_summary.html",
        filtered_matrix = f"{OUTPUT_DIR}/{SAMPLE_ID}/outs/filtered_feature_bc_matrix.h5"
    output:
        summary_report = f"{OUTPUT_DIR}/{SAMPLE_ID}_analysis_summary.txt"
    shell:
        """
        echo "CellRanger analysis completed for sample: {SAMPLE_ID}" > {output.summary_report}
        echo "Web summary: {input.web_summary}" >> {output.summary_report}
        echo "Filtered matrix: {input.filtered_matrix}" >> {output.summary_report}
        echo "Analysis timestamp: $(date)" >> {output.summary_report}
        """
