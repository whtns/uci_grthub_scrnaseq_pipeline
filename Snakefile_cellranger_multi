# Multi-sample CellRanger Snakemake workflow
# For processing multiple single-cell RNA-seq samples

# Load configuration
configfile: "config_cellranger_multi.yaml"

# Extract sample list and configuration
SAMPLES = config["samples"]
FASTQ_DIR = config["paths"]["fastqs"]
TRANSCRIPTOME = config["references"]["transcriptome"]
OUTPUT_DIR = config["paths"]["output"]

# Rule all - defines final outputs for all samples
rule all:
    input:
        expand(f"{OUTPUT_DIR}/{{sample}}/outs/web_summary.html", sample=SAMPLES),
        expand(f"{OUTPUT_DIR}/{{sample}}/outs/filtered_feature_bc_matrix.h5", sample=SAMPLES),
        f"{OUTPUT_DIR}/multi_sample_summary.txt"

# Rule: CellRanger count for each sample
rule cellranger_count:
    input:
        fastq_dir = f"{FASTQ_DIR}/{{sample}}"
    output:
        web_summary = f"{OUTPUT_DIR}/{{sample}}/outs/web_summary.html",
        filtered_matrix = f"{OUTPUT_DIR}/{{sample}}/outs/filtered_feature_bc_matrix.h5",
        bam_file = f"{OUTPUT_DIR}/{{sample}}/outs/possorted_genome_bam.bam",
        molecule_info = f"{OUTPUT_DIR}/{{sample}}/outs/molecule_info.h5"
    params:
        transcriptome = TRANSCRIPTOME,
        output_dir = OUTPUT_DIR,
        localcores = config["params"]["localcores"],
        localmem = config["params"]["localmem"]
    threads: 8
    resources:
        mem_mb = 131072,  # 128GB in MB
        cpus = 8,
        partition = "standard",
        account = "SBSANDME_LAB"
    shell:
        """
        module load cellranger/8.0.1
        
        rm  -rf {wildcards.sample}

        cellranger count --id={wildcards.sample} \
        --transcriptome={params.transcriptome} \
        --create-bam=true \
        --fastqs={input.fastq_dir} \
        --localcores={params.localcores} \
        --localmem={params.localmem}

        mv {wildcards.sample} {params.output_dir}/{wildcards.sample}
        
        module unload cellranger/8.0.1
        """

# Rule: Generate multi-sample summary
rule multi_sample_summary:
    input:
        web_summaries = expand(f"{OUTPUT_DIR}/{{sample}}/outs/web_summary.html", sample=SAMPLES)
    output:
        summary = f"{OUTPUT_DIR}/multi_sample_summary.txt"
    run:
        with open(output.summary, 'w') as f:
            f.write("CellRanger Multi-Sample Analysis Summary\n")
            f.write("=" * 40 + "\n\n")
            f.write(f"Analysis completed: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"Total samples processed: {len(SAMPLES)}\n\n")
            
            for sample in SAMPLES:
                f.write(f"Sample: {sample}\n")
                f.write(f"  - Web summary: {OUTPUT_DIR}/{sample}/outs/web_summary.html\n")
                f.write(f"  - Filtered matrix: {OUTPUT_DIR}/{sample}/outs/filtered_feature_bc_matrix.h5\n")
                f.write(f"  - BAM file: {OUTPUT_DIR}/{sample}/outs/possorted_genome_bam.bam\n\n")
